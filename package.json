{
  "name": "ss-2",
  "version": "1.0.12",
  "author": "Q3 Labs",
  "license": "MIT",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/snfoundry",
      "packages/nextjs"
    ]
  },
  "scripts": {
    "chain": "yarn workspace @ss-2/snfoundry chain",
    "deploy": "yarn workspace @ss-2/snfoundry deploy",
    "deploy:clear": "yarn workspace @ss-2/snfoundry deploy:clear",
    "deploy:no-reset": "yarn workspace @ss-2/snfoundry deploy --no-reset",
    "test": "yarn workspace @ss-2/snfoundry test",
    "compile": "yarn workspace @ss-2/snfoundry compile",
    "start": "yarn workspace @ss-2/nextjs dev",
    "next:lint": "yarn workspace @ss-2/nextjs lint",
    "next:check-types": "yarn workspace @ss-2/nextjs check-types",
    "vercel": "yarn workspace @ss-2/nextjs vercel",
    "vercel:yolo": "yarn workspace @ss-2/nextjs vercel:yolo",
    "test:nextjs": "yarn workspace @ss-2/nextjs test",
    "format": "yarn workspace @ss-2/nextjs format && yarn workspace @ss-2/snfoundry format",
    "format:check": "yarn workspace @ss-2/nextjs format:check && yarn workspace @ss-2/snfoundry format:check",
    "prepare": "husky",
    "verify": "yarn workspace @ss-2/snfoundry verify",
    "stellar:build": "cd packages/soroban && cargo build --release --target wasm32-unknown-unknown",
    "stellar:test": "cd packages/soroban && cargo test",
    "stellar:fmt": "cd packages/soroban && cargo fmt",
    "stellar:fmt:check": "cd packages/soroban && cargo fmt -- --check",
    "stellar:deploy:testnet": "cd packages/soroban && stellar contract deploy --wasm target/wasm32-unknown-unknown/release/soroban_lottery.wasm --network testnet --source-account default",
    "stellar:deploy:mainnet": "cd packages/soroban && stellar contract deploy --wasm target/wasm32-unknown-unknown/release/soroban_lottery.wasm --network mainnet --source-account default"
  },
  "packageManager": "yarn@3.2.3",
  "devDependencies": {
    "@next/swc-linux-x64-gnu": "^15.3.1",
    "@next/swc-linux-x64-musl": "^15.3.1",
    "daisyui": "^4.7.3",
    "husky": "^9.0.11",
    "pinst": "^3.0.0",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tsparticles/path-curves": "^3.8.1",
    "framer-motion": "^12.23.22",
    "i18next": "^25.3.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "postcss": "^8.4.38",
    "react-countup": "^6.5.3",
    "react-i18next": "^15.6.0",
    "react-tsparticles": "^2.12.2",
    "tsparticles": "^3.8.1"
  }
}
